# Copy to .env.local and fill in your values.
# Supabase project: https://supabase.com/dashboard → Project Settings → API / Database

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
FORCE_SUPABASE=1

# ── WhatsApp auto-send (Meta Cloud API — recommended) ───────────────
# 1. https://developers.facebook.com → Create App → WhatsApp use case
# 2. WhatsApp → API Setup → copy Phone number ID + access token
# 3. Add test guard numbers under API Setup → "To"
# 4. Set the same vars in Vercel → Environment Variables → redeploy
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Optional — Twilio WhatsApp
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
