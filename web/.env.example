# Copy to .env.local and fill in your values.
# Supabase project: https://supabase.com/dashboard → Project Settings → API / Database

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
FORCE_SUPABASE=1

# Server-side only (Vercel → Settings → Environment Variables). Never expose in the browser.
# Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ── Email PIN delivery (recommended for mobile app testing) ───────
# Sign up at resend.com → API Keys → create key
# Testing: EMAIL_FROM=onboarding@resend.dev (only sends to your Resend account email)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ── Messaging (optional — WhatsApp/SMS) ───────────────────────────

# Option A — Twilio SMS (recommended if Meta verification blocked)
# Sign up at twilio.com → buy SMS number → verify guard numbers on trial
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1234567890

# Option B — Twilio WhatsApp sandbox (no Meta developer portal)
# Console → Messaging → WhatsApp sandbox → guards send "join <code>" to +14155238886
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Option C — Meta WhatsApp Cloud API (optional; requires Meta dev SMS verification)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_CLOUD_TOKEN=
# WHATSAPP_API_VERSION=v21.0
