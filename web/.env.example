# Copy to .env.local and fill in your values.
# Supabase project: https://supabase.com/dashboard → Project Settings → API / Database

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Or direct: postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Copy from Supabase → Project Settings → Database → Connection string → URI
FORCE_SUPABASE=1

# Server-side only (Vercel → Settings → Environment Variables). Never expose in the browser.
# Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ── Email PIN delivery (guards + supervisors) ─────────────────────
# Sign up at resend.com → API Keys → create key
# Testing: EMAIL_FROM=onboarding@resend.dev (only sends to your Resend account email)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# WhatsApp: manual only (wa.me links). No Twilio or Meta keys required.
